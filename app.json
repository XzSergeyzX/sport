{
  "expo": {
    "name": "Sporty_SM",
    "slug": "Sporty_SM",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sportysm",
    "userInterfaceStyle": "dark",
    "androidNavigationBar": {
      "barStyle": "light-content",
      "backgroundColor": "#16191F"
    },
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.sportysm.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-localization",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Sporty to use the microphone for voice messages to the coach."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1FB89A"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eaccb3d3-2a8f-4fb4-9e1e-d78c05cbde80"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/eaccb3d3-2a8f-4fb4-9e1e-d78c05cbde80"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
